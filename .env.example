PORT=3000 #端口号
APP_USERNAME=admin
APP_PASSWORD=admin #请务必更改密码
SESSION_SECRET=replace-with-a-long-random-string
# Optional TOTP secret for 2FA. Generate one with: openssl rand -base64 20
# Then convert/store as Base32 for authenticator apps, or leave empty to disable 2FA in local development.
APP_TOTP_SECRET= 
# Comma-separated hostnames or IPs allowed for SSH connections. Leave empty to allow all.
SSH_ALLOWED_HOSTS=
